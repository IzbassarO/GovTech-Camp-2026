# Base URL of the DÁLEL Eco demo API (FastAPI). No secrets here.
#
# Default assumes the API on port 8000. If port 8000 is occupied by an
# unrelated local service, start the API on another port and point this at
# it, e.g.:
#   uv run uvicorn dalel.api.app:app --reload --port 8011
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8011
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
